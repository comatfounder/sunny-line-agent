# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# 業主 LINE User ID（admin 指令識別）
# 取得方式：先讓業主傳一則訊息，從 Railway log 或 Sheets 對話記錄取得
FOUNDER_LINE_USER_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# 預設 claude-sonnet-4-5，可換成 claude-opus-4-5（品質更高但較貴）
CLAUDE_MODEL=claude-sonnet-4-5

# Google Sheets
# GOOGLE_CREDENTIALS_JSON：GCP Service Account JSON 金鑰完整內容（一整個 JSON 字串）
# 建議直接在 Railway Dashboard 貼上，不要用 CLI（容易截斷）
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_SHEET_ID=your_google_sheet_id_here
